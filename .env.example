# Demo Mode
# Set to 'true' to run without a Drupal backend using sample data.
# NEXT_PUBLIC_DEMO_MODE=true

# Drupal Configuration
NEXT_PUBLIC_DRUPAL_BASE_URL=https://your-site.decoupled.website

# OAuth2 Client Credentials
DRUPAL_CLIENT_ID=your-client-id-here
DRUPAL_CLIENT_SECRET=your-client-secret-here

# Revalidation Secret
DRUPAL_REVALIDATE_SECRET=your-revalidate-secret-here

# Site Configuration (Optional)
# NEXT_PUBLIC_SITE_URL=https://www.example.com
